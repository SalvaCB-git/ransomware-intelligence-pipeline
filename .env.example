# Configuración del SERVIDOR (contenedor Flask). Copiar a .env y rellenar.
# .env está gitignored: NUNCA versionar valores reales.

# Clave de Google AI Studio. Solo necesaria para el juez v2 en línea
# (judge_core.py / judge_v2.py); las cifras estrella se reproducen sin ella.
GOOGLE_API_KEY=

# Credencial HTTP Basic Auth de los endpoints de mutación y del pipeline
# cliente-servidor (las páginas de demo y las APIs read-only son públicas).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
